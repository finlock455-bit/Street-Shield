-------------------------------------------+            "name": "Rainy Weather Scenario",
-------------------------------------------+            "location": {"latitude": 40.7128, "longitude": -74.0060, "timestamp": datetime.utcnow().isoformat()},
-------------------------------------------+            "user_context": {"activity": "running", "speed": 2.5, "user_id": "ai_test_1"}
